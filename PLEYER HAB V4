-- Feature: Fly (FIXED: Direct Input Polling)
local function cleanFlyObjects()
    for _, obj in ipairs(FlyObjects) do
        pcall(function() if obj and obj.Parent then obj:Destroy() end end)
    end
    FlyObjects = {}
end

local function stopFly()
    State.fly = false
    disc("fly")
    cleanFlyObjects()
    local hum = getHumanoid()
    if hum then
        hum.PlatformStand = false
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    end
end

local function startFly()
    local tries = 0
    repeat task.wait(0.05); tries += 1 until (getHRP() and getHumanoid()) or tries > 40
    if not getHRP() then return end

    cleanFlyObjects()
    local hrp   = getHRP()
    local hum   = getHumanoid()
    local cam   = workspace.CurrentCamera

    local att = Instance.new("Attachment")
    att.Name="_FlyAtt"; att.Parent=hrp
    table.insert(FlyObjects, att)

    local lv = Instance.new("LinearVelocity")
    lv.Attachment0=att; lv.MaxForce=math.huge
    lv.VectorVelocity=Vector3.zero
    lv.RelativeTo=Enum.ActuatorRelativeTo.World
    lv.Parent=hrp
    table.insert(FlyObjects, lv)

    local ao = Instance.new("AlignOrientation")
    ao.Attachment0=att; ao.Mode=Enum.OrientationAlignmentMode.OneAttachment
    ao.MaxTorque=math.huge; ao.Responsiveness=50
    ao.RigidityEnabled=true; ao.Parent=hrp
    table.insert(FlyObjects, ao)

    local ag = Instance.new("VectorForce")
    ag.Attachment0=att
    ag.Force=Vector3.new(0, workspace.Gravity * hrp.AssemblyMass, 0)
    ag.RelativeTo=Enum.ActuatorRelativeTo.World
    ag.ApplyAtCenterOfMass=true; ag.Parent=hrp
    table.insert(FlyObjects, ag)

    hum.PlatformStand = true
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)

    Connections.fly = RunService.RenderStepped:Connect(function()
        if not State.fly or not hrp.Parent then stopFly(); return end
        
        -- Stop moving if player is typing in chat/UI
        if UserInputService:GetFocusedTextBox() then
            lv.VectorVelocity = Vector3.zero
            return
        end

        local cf = cam.CFrame
        local mv = Vector3.zero
        
        -- Direct real-time polling to prevent stuck keys
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv += cf.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv -= cf.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv -= cf.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv += cf.RightVector end
        
        if CONFIG.FLY_QE_VERTICAL then
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then mv += Vector3.yAxis end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mv -= Vector3.yAxis end
        end
        
        if mv.Magnitude > 0 then mv = mv.Unit end
        lv.VectorVelocity = mv * (State.flySpeed * CONFIG.FLY_SPEED_MUL)
        ao.CFrame = cf
    end)
end

local function setFly(enabled)
    State.fly = enabled
    if enabled then startFly() else stopFly() end
end

-- Kill Script
local function killScript()
    setFly(false); setNoclip(false)
    setFullbright(false); setAntiAFK(false)
    State.infJump   = false
    State.lockSpeed = false
    State.lockJump  = false
    disc("statEnforce")
    disc("jumpReq"); disc("charAdded")
    local hum = getHumanoid()
    if hum then
        hum.WalkSpeed = CONFIG.WALK_SPEED_DEF
        hum.JumpPower = CONFIG.JUMP_POWER_DEF
    end
end

-- Character lifecycle
local function onCharAdded(char)
    char:WaitForChild("Humanoid", 10)
    char:WaitForChild("HumanoidRootPart", 10)
    applyMovementStats(char)
    if State.fly then task.delay(0.25, startFly) end
end

