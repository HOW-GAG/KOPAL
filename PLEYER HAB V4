        local dl=mLabel(row,desc,9,CONFIG.TEXT3,Enum.Font.Gotham)
        dl.Size=UDim2.new(1,-74,0,13); dl.Position=UDim2.new(0,12,0,28)
    end

    local val=initVal

    local pill=Instance.new("TextButton")
    pill.Size=UDim2.new(0,46,0,24); pill.Position=UDim2.new(1,-56,0.5,-12)
    pill.BackgroundColor3=val and CONFIG.SUCCESS or CONFIG.BG5
    pill.Text=""; pill.AutoButtonColor=false; pill.Parent=row; corner(pill,12)

    local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,18,0,18)
    knob.Position=UDim2.new(0,val and 24 or 4,0.5,-9)
    knob.BackgroundColor3=CONFIG.TEXT1; knob.BorderSizePixel=0
    knob.Parent=pill; corner(knob,9)

    local function setState(v)
        val=v
        tw(pill,{BackgroundColor3=v and CONFIG.SUCCESS or CONFIG.BG5},0.15):Play()
        tw(knob,{Position=UDim2.new(0,v and 24 or 4,0.5,-9)},0.15):Play()
        if callback then callback(v) end
    end

    local pillClicked=false
    pill.MouseButton1Click:Connect(function()
        pillClicked=true; setState(not val)
        task.defer(function() pillClicked=false end)
    end)
    row.MouseButton1Click:Connect(function()
        if pillClicked then return end
        setState(not val)
    end)

    return setState
end

local function makeSlider(label, minV, maxV, defVal, suffix, callback)
    local row=Instance.new("Frame"); row.Size=UDim2.new(1,-2,0,62)
    row.BackgroundColor3=CONFIG.BG3; row.BorderSizePixel=0
    row.LayoutOrder=nextOrd(); row.Parent=Scroll; corner(row,9)
    uiStroke(row,Color3.fromRGB(28,28,50),1)

    local lbl=mLabel(row,label,12,CONFIG.TEXT1,Enum.Font.GothamBold)
    lbl.Size=UDim2.new(1,-82,0,16); lbl.Position=UDim2.new(0,12,0,9)

    local valLbl=mLabel(row,tostring(defVal)..(suffix or ""),11,CONFIG.ACCENT,
        Enum.Font.GothamBold,Enum.TextXAlignment.Right)
    valLbl.Size=UDim2.new(0,72,0,16); valLbl.Position=UDim2.new(1,-84,0,9)

    local track=Instance.new("Frame"); track.Size=UDim2.new(1,-24,0,6)
    track.Position=UDim2.new(0,12,0,38); track.BackgroundColor3=CONFIG.BG5
    track.BorderSizePixel=0; track.Parent=row; corner(track,3)

    local fill=Instance.new("Frame"); fill.Size=UDim2.new(0,0,1,0)
    fill.BackgroundColor3=CONFIG.ACCENT; fill.BorderSizePixel=0
    fill.Parent=track; corner(fill,3)

    local knob=Instance.new("TextButton"); knob.Size=UDim2.new(0,16,0,16)
    knob.AnchorPoint=Vector2.new(0.5,0.5); knob.Position=UDim2.new(0,0,0.5,0)
    knob.BackgroundColor3=CONFIG.TEXT1; knob.Text=""
    knob.AutoButtonColor=false; knob.BorderSizePixel=0
    knob.ZIndex=3; knob.Parent=track; corner(knob,8)

    local curVal=defVal
    local isDrag=false

    local function updateVisual(v)
        local pct=(v-minV)/(maxV-minV)
        fill.Size=UDim2.new(pct,0,1,0)
        knob.Position=UDim2.new(pct,0,0.5,0)
        valLbl.Text=tostring(v)..(suffix or "")
    end
    updateVisual(defVal)

    local function screenXToVal(absX)
        local tPos=track.AbsolutePosition.X
        local tW=track.AbsoluteSize.X
        local pct=math.clamp((absX-tPos)/tW,0,1)
        return math.floor(minV+pct*(maxV-minV))
    end

    local function applyVal(v)
        v=math.clamp(math.floor(v),minV,maxV)
        curVal=v; updateVisual(v)
        if callback then callback(v) end
    end

    knob.MouseButton1Down:Connect(function() isDrag=true end)
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then
            isDrag=true; applyVal(screenXToVal(inp.Position.X))
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if isDrag and inp.UserInputType==Enum.UserInputType.MouseMovement then
            applyVal(screenXToVal(inp.Position.X))
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
    end)

    return function(v) applyVal(v) end
end

