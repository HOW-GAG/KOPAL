--// Functions
local function disc(key)
    if Connections[key] then
        pcall(function() Connections[key]:Disconnect() end)
        Connections[key] = nil
    end
end

local function getChar()   return LP.Character end
local function getHumanoid()
    local c = getChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end
local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

-- Feature: Speed / Jump enforcement loop
local function startStatEnforcement()
    disc("statEnforce")
    Connections.statEnforce = RunService.Heartbeat:Connect(function()
        local hum = getHumanoid()
        if not hum then return end

        if State.lockSpeed and hum.WalkSpeed ~= State.walkSpeed then
            hum.WalkSpeed = State.walkSpeed
        end
        if State.lockJump and hum.JumpPower ~= State.jumpPower then
            hum.JumpPower = State.jumpPower
        end
    end)
end

local function applyMovementStats(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = State.walkSpeed
        hum.JumpPower = State.jumpPower
    end
end

-- Feature: Infinite Jump
local function onJumpRequest()
    if not State.infJump then return end
    local hum = getHumanoid()
    if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
end

-- Feature: NoClip
local function noclipStep()
    local c = getChar(); if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end

local function restoreCollision()
    local c = getChar(); if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = true end
    end
end

local function setNoclip(enabled)
    State.noclip = enabled
    disc("noclip")
    if enabled then
        Connections.noclip = RunService.Stepped:Connect(noclipStep)
    else
        restoreCollision()
    end
end

-- Feature: Fullbright
local function setFullbright(enabled)
    State.fullbright = enabled
    disc("fullbright")
    if enabled then
        LightingBk = {
            Brightness    = Lighting.Brightness,
            Ambient       = Lighting.Ambient,
            ClockTime     = Lighting.ClockTime,
            FogEnd        = Lighting.FogEnd,
            GlobalShadows = Lighting.GlobalShadows,
        }
        Connections.fullbright = RunService.RenderStepped:Connect(function()
            Lighting.Brightness    = CONFIG.FB_BRIGHTNESS
            Lighting.ClockTime     = CONFIG.FB_CLOCK
            Lighting.FogEnd        = CONFIG.FB_FOG_END
            Lighting.GlobalShadows = false
            Lighting.Ambient       = CONFIG.FB_AMBIENT
        end)
    else
        if LightingBk.Ambient then
            Lighting.Brightness    = LightingBk.Brightness
            Lighting.Ambient       = LightingBk.Ambient
            Lighting.ClockTime     = LightingBk.ClockTime
            Lighting.FogEnd        = LightingBk.FogEnd
            Lighting.GlobalShadows = LightingBk.GlobalShadows
        end
    end
end

-- Feature: Anti-AFK
