--// Utilities
local function tween(obj, props, t, style, dir)
	TweenService:Create(obj, TweenInfo.new(t or CONFIG.UI.AnimSpeed, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props):Play()
end

local function applyCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or CONFIG.UI.CornerRadius)
	c.Parent = parent
	return c
end

local function applyStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or CONFIG.Colors.Border
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0.5
	s.Parent = parent
	return s
end

--// File I/O
local function loadSavedData()
	if isfile and readfile then
		local ok, raw = pcall(readfile, CONFIG.SaveFileName)
		if ok and raw then
			local ok2, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
			if ok2 and type(decoded) == "table" then
				savedStickersDB = decoded
			end
		end
	end
end

local function saveCurrentData()
	if writefile then
		local ok, enc = pcall(function() return HttpService:JSONEncode(savedStickersDB) end)
		if ok then pcall(writefile, CONFIG.SaveFileName, enc) end
	end
end

--// Cleanup
local function cleanupOldGUI()
	local existing = guiContainer:FindFirstChild("StickerVaultV3")
	if existing then existing:Destroy() end
	for _, c in ipairs(activeConnections) do
		if c.Connected then c:Disconnect() end
	end
	table.clear(activeConnections)
	table.clear(uiInstances)
end

local function extractAssetId(tex)
	return tex and string.match(tex, "%d+") or nil
end

local function getStickerFolder(jeepney)
	local b = jeepney:FindFirstChild("Body")
	if not b then return nil end
	local s = b:FindFirstChild("Structure")
	if not s then return nil end
	local c = s:FindFirstChild("Customizables")
	if not c then return nil end
	return c:FindFirstChild("Stickers")
end

--// Webhook Logic
local function sendWebhook(id, ownerName, btnRef)
	if not httprequest then return end
	btnRef.Text = "..."
	local thumbUrl = ""
	
	local tSuccess, tRes = pcall(function()
		return httprequest({
			Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. id .. "&returnPolicy=PlaceHolder&size=420x420&format=Png&isCircular=false",
			Method = "GET"
		})
	end)
	if tSuccess and tRes and tRes.Body then
		local decoded = HttpService:JSONDecode(tRes.Body)
		if decoded and decoded.data and decoded.data[1] and decoded.data[1].imageUrl then thumbUrl = decoded.data[1].imageUrl end
	end

	local payload = {
		username = "StickerVault Architect",
		embeds = {{
			title = "Jeepney Sticker Captured",
			description = "**Asset ID:** `" .. id .. "`\n**Source:** `" .. ownerName .. "`\n**Link:** [View in Catalog](https://www.roblox.com/library/" .. id .. "/decal)",
			color = tonumber(0x6e56ff),
			image = { url = thumbUrl ~= "" and thumbUrl or nil },
			footer = { text = "StickerVault v3.1 Database Transfer" }
		}}
	}

	local wSuccess = pcall(function()
		return httprequest({ Url = CONFIG.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload) })
	end)

	if wSuccess then
		btnRef.Text = "SENT ✓"
		tween(btnRef, {BackgroundColor3 = CONFIG.Colors.SaveDim}, 0.2)
		btnRef.Active = false
		savedStickersDB[id].sent = true
		saveCurrentData()
	else
		btnRef.Text = "FAIL"
		task.wait(1)
		btnRef.Text = "DISCORD"
	end
end

local function syncAllToDiscord(btnRef)
	if not httprequest then return end
	
	-- Gather unsent stickers
	local unsent = {}
	for id, data in pairs(savedStickersDB) do
		if not data.sent then
			table.insert(unsent, {id = id, owner = data.owner})
		end
	end

	if #unsent == 0 then
		btnRef.Text = "ALL SYNCED ✓"
		task.wait(2)
		btnRef.Text = "SYNC ALL TO DISCORD"
		return
	end

	btnRef.Text = "SYNCING ("..#unsent..")..."
	
	-- Process in chunks of 10 (Discord limit per message)
	for i = 1, #unsent, 10 do
		local chunk = {}
		local idsForThumb = {}
		for j = i, math.min(i + 9, #unsent) do
			table.insert(chunk, unsent[j])
			table.insert(idsForThumb, unsent[j].id)
		end
		
		-- Batch fetch thumbnails
		local thumbs = {}
		local tSuccess, tRes = pcall(function()
			return httprequest({
				Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. table.concat(idsForThumb, ",") .. "&returnPolicy=PlaceHolder&size=420x420&format=Png&isCircular=false",
				Method = "GET"
			})
		end)
		if tSuccess and tRes and tRes.Body then
			local dec = HttpService:JSONDecode(tRes.Body)
			if dec and dec.data then
				for _, tData in ipairs(dec.data) do
					thumbs[tostring(tData.targetId)] = tData.imageUrl
				end
			end
		end

		local embeds = {}
		for _, item in ipairs(chunk) do
			table.insert(embeds, {
				title = "Jeepney Sticker Captured",
				description = "**Asset ID:** `" .. item.id .. "`\n**Source:** `" .. item.owner .. "`\n**Link:** [View in Catalog](https://www.roblox.com/library/" .. item.id .. "/decal)",
				color = tonumber(0x6e56ff),
				image = { url = thumbs[item.id] or nil },
				footer = { text = "StickerVault Batch Sync" }
			})
		end

		local payload = { username = "StickerVault Architect", embeds = embeds }
		local wSuccess = pcall(function()
			return httprequest({ Url = CONFIG.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload) })
		end)

		if wSuccess then
			for _, item in ipairs(chunk) do
				savedStickersDB[item.id].sent = true
			end
			saveCurrentData()
		end
		
		if i + 9 < #unsent then
			task.wait(1.5) -- Prevent Discord ratelimiting
		end
	end
	
	btnRef.Text = "SYNC COMPLETE ✓"
	refreshSavedUI() -- Update the individual buttons visually
	task.wait(2)
	btnRef.Text = "SYNC ALL TO DISCORD"
end

