function refreshActiveUI()
	if not uiInstances.ActiveScroll then return end
	for _, c in ipairs(uiInstances.ActiveScroll:GetChildren()) do if c:IsA("GuiObject") then c:Destroy() end end
	if targetFolder then
		for _, jeepney in ipairs(targetFolder:GetChildren()) do
			local sf = getStickerFolder(jeepney)
			if sf then
				for _, obj in ipairs(sf:GetChildren()) do
					local decal = obj:FindFirstChildWhichIsA("Decal") or obj:FindFirstChildWhichIsA("Texture")
					if decal and decal.Texture ~= "" then
						local id = extractAssetId(decal.Texture)
						if id then createStickerEntry(uiInstances.ActiveScroll, id, jeepney.Name, false) end
					end
				end
			end
		end
	end
	task.defer(function() uiInstances.ActiveScroll.CanvasSize = UDim2.new(0, 0, 0, uiInstances.ActiveLayout.AbsoluteContentSize.Y + 10) end)
end

function refreshSavedUI()
	if not uiInstances.SavedScroll then return end
	for _, c in ipairs(uiInstances.SavedScroll:GetChildren()) do if c:IsA("GuiObject") then c:Destroy() end end
	for id, data in pairs(savedStickersDB) do createStickerEntry(uiInstances.SavedScroll, id, data.owner, true) end
	task.defer(function() uiInstances.SavedScroll.CanvasSize = UDim2.new(0, 0, 0, uiInstances.SavedLayout.AbsoluteContentSize.Y + 10) end)
end

-----------------------------
-- Initialization
-----------------------------
loadSavedData()
createUI()
refreshSavedUI()

if targetFolder then
	refreshActiveUI()
	table.insert(activeConnections, targetFolder.ChildAdded:Connect(function() task.wait(1.5); refreshActiveUI() end))
	table.insert(activeConnections, targetFolder.ChildRemoved:Connect(function() refreshActiveUI() end))
end
