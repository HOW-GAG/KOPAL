-- SECTION 7: TRIGGER BOT ENGINE
-- Same smart pierce filter as LoS, dedicated ray pool to avoid conflicts.
--=============================================================================

local lastMouseMoveTime = 0
local lastShotTime      = 0

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        lastMouseMoveTime = tick()
    end
end)

-- Pierce raycast for trigger bot.
-- CRITICAL: Only pierce through shouldPierceHit-approved objects.
-- Character detection uses direct parent Humanoid check, NOT FindFirstAncestorOfClass
-- (which matches map Model folders and causes wall-piercing).
local function triggerPierceRay(unitRayOrigin, unitRayDir, maxRange)
    triggerPoolClear()
    if player.Character then triggerPoolAdd(player.Character) end

    local origin    = unitRayOrigin
    local direction = unitRayDir * maxRange

    for _ = 1, RayConfig.TriggerMaxPierce do
        triggerRayParams.FilterDescendantsInstances = triggerIgnorePool
        local hit = workspace:Raycast(origin, direction, triggerRayParams)

        if not hit then return nil end

        local hitPart = hit.Instance
        local parent = hitPart.Parent

        -- Check if we directly hit a character's body part.
        -- A character Model has a Humanoid as a direct child.
        -- We check the PARENT of the hit part, not FindFirstAncestorOfClass,
        -- because map geometry is often nested in Models too.
        if parent and parent:IsA("Model") and parent:FindFirstChildOfClass("Humanoid") then
            local targetPlayer = Players:GetPlayerFromCharacter(parent)
            if targetPlayer and targetPlayer ~= player and not shouldSkip(targetPlayer) then
                return targetPlayer
            end
            -- Same-team or NPC ‚ÄĒ pierce past this character
            triggerPoolAdd(parent)
        elseif parent and (parent:IsA("Accessory") or parent:IsA("Tool")) then
            -- Hit an accessory/tool handle ‚ÄĒ check if its grandparent is a target character
            local grandparent = parent.Parent
            if grandparent and grandparent:IsA("Model") and grandparent:FindFirstChildOfClass("Humanoid") then
                local targetPlayer = Players:GetPlayerFromCharacter(grandparent)
                if targetPlayer and targetPlayer ~= player and not shouldSkip(targetPlayer) then
                    return targetPlayer
                end
                triggerPoolAdd(grandparent)
            else
                -- Orphaned accessory/tool ‚ÄĒ pierce it
                triggerPoolAdd(hitPart)
            end
        elseif shouldPierceHit(hitPart) then
            -- Non-character filtered object (invisible boundary, effect, etc.)
            triggerPoolAdd(hitPart)
        else
            -- Solid wall. Stop here.
            return nil
        end

        -- Advance past hit point
        local hitPos  = hit.Position + hit.Normal * 0.01
        local remaining = maxRange - (hitPos - unitRayOrigin).Magnitude
        if remaining < 1 then return nil end
        direction = unitRayDir * remaining
        origin    = hitPos
    end

    return nil
end

RunService.RenderStepped:Connect(function()
    if not Config.TriggerBot then return end

    -- Activation mode gating
    if Config.TriggerMode == 2 then
        if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    elseif Config.TriggerMode == 3 then
        if tick() - lastMouseMoveTime > 0.15 then return end
    end

    local now = tick()
    if now - lastShotTime < RayConfig.TriggerFireDelay then return end

    local mouse   = player:GetMouse()
    local unitRay = mouse.UnitRay

    local targetPlayer = triggerPierceRay(unitRay.Origin, unitRay.Direction, 1000)
    if not targetPlayer then return end

    lastShotTime = now

    if mouse1press then
        task.spawn(function()
            mouse1press()
            task.wait(0.01)
            if mouse1release then mouse1release() end
        end)
    elseif mouse1click then
        task.spawn(mouse1click)
    else
        task.spawn(function()
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, true, game, 1)
            task.wait(0.01)
            vim:SendMouseButtonEvent(mouse.X, mouse.Y, 0, false, game, 1)
        end)
    end
end)

