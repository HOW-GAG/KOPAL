    s.TextSize           = 10
    s.TextColor3         = Color3.fromRGB(80, 100, 200)
    s.TextXAlignment     = Enum.TextXAlignment.Left
    s.Parent             = parent
end

local function makeCycle(parent, text, yOffset, options, defaultIndex, onCycle)
    makeLabel(parent, text, yOffset)

    local Btn = Instance.new("TextButton")
    Btn.Size             = UDim2.new(0, 80, 0, 22)
    Btn.Position         = UDim2.new(1, -96, 0, yOffset - 1)
    Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    Btn.BorderSizePixel  = 0
    Btn.Text             = options[defaultIndex]
    Btn.Font             = Enum.Font.GothamBold
    Btn.TextSize         = 10
    Btn.TextColor3       = Color3.fromRGB(200, 205, 230)
    Btn.Parent           = parent

    local UIC = Instance.new("UICorner")
    UIC.CornerRadius = UDim.new(0, 6)
    UIC.Parent = Btn

    local index = defaultIndex
    Btn.MouseButton1Click:Connect(function()
        index = index + 1
        if index > #options then index = 1 end
        Btn.Text = options[index]
        onCycle(index)
    end)
end

