--=============================================================================
-- SECTION 1: MEMORY POOLS & CACHES
-- Pre-allocated structures. Zero per-frame table creation in hot paths.
--=============================================================================

-- LoS raycast params (dedicated instance, never shared with trigger)
local losRayParams = RaycastParams.new()
losRayParams.FilterType = Enum.RaycastFilterType.Exclude

-- Ignore list pool: indexed writes + size counter instead of table.insert
-- Objects pierced during one limb stay in the pool for subsequent limbs
-- of the same player (intentional: avoids re-piercing the same object)
local ignorePool = table.create(64)
local ignorePoolSize = 0

local function poolClear()
    table.clear(ignorePool)
    ignorePoolSize = 0
end

local function poolAdd(obj)
    ignorePoolSize += 1
    ignorePool[ignorePoolSize] = obj
end

-- Trigger bot has its own pool to avoid conflicts with LoS updates
local triggerRayParams = RaycastParams.new()
triggerRayParams.FilterType = Enum.RaycastFilterType.Exclude

local triggerIgnorePool = table.create(32)
local triggerIgnoreSize = 0

local function triggerPoolClear()
    table.clear(triggerIgnorePool)
    triggerIgnoreSize = 0
end

local function triggerPoolAdd(obj)
    triggerIgnoreSize += 1
    triggerIgnorePool[triggerIgnoreSize] = obj
end

-- Visibility cache: two parallel flat tables so we don't allocate a {v,t}
-- wrapper table for every single cached entry
local visCacheResult = {}  -- [BasePart] -> boolean
local visCacheTime   = {}  -- [BasePart] -> number (tick)
local visCacheCount  = 0

local function visCacheGet(part)
    local t = visCacheTime[part]
    if t and (tick() - t) < RayConfig.VisCacheTTL then
        return visCacheResult[part], true
    end
    return nil, false
end

local function visCacheSet(part, visible)
    if not visCacheTime[part] then
        visCacheCount += 1
    end
    visCacheResult[part] = visible
    visCacheTime[part] = tick()
end

local function visCacheFlush()
    table.clear(visCacheResult)
    table.clear(visCacheTime)
    visCacheCount = 0
end

-- Team lookup cache: avoid repeated workspace traversal for team folder names
local teamCache     = {}
local teamCacheTick = 0

--=============================================================================
-- SECTION 2: SMART PIERCE FILTER
--
-- Philosophy: ONLY pierce objects we are CERTAIN are not real walls.
-- Ambiguous geometry (semi-transparent MeshParts, thin walls, CSG with
-- slight transparency) is treated as solid. The multi-ray fallback in
-- Section 3 handles edge cases geometrically instead of guessing.
--
-- Three confidence tiers:
--   Tier 1 ‚ÄĒ Engine facts: CanCollide, Transparency ‚Č• 0.9, named capsules
--   Tier 2 ‚ÄĒ Structural context: Accessories, characters, effect folders
--   Tier 3 ‚ÄĒ Conservative heuristic: Transparency ‚Č• 0.75 (tunable)
--=============================================================================

-- O(1) name lookup for known invisible collision parts
local ALWAYS_PIERCE_NAMES = {
    HumanoidRootPart = true,   -- Invisible collision capsule, never rendered
    Handle           = true,   -- Accessory/Tool mesh handle (sometimes re-parented)
}

-- Parent folder names that contain non-gameplay objects (effects, projectiles, etc.)
local PIERCE_PARENT_NAMES = {
    ignore      = true,
    debris      = true,
    effects     = true,
    particles   = true,
    bullets     = true,
    projectiles = true,
    sounds      = true,
    fx          = true,
    vfx         = true,
    rays        = true,
}

local function shouldPierceHit(hitPart)
    --=================================================================
    -- TIER 1: ENGINE FACTS
    -- These are objectively not walls. Zero ambiguity.
    --=================================================================

    -- If the engine itself won't collide with it, it's not an obstacle.
    -- Triggers, zones, kill bricks, non-solid decorations.
    if not hitPart.CanCollide then
        return true
    end

    -- Effectively invisible parts (Transparency ‚Č• 0.9).
    -- At this level the player literally cannot see the object.
    -- This is a hard threshold that won't catch glass/tinted walls (0.3‚Äď0.5).
    if hitPart.Transparency >= 0.9 then
        return true
    end

    -- Named invisible collision geometry (HumanoidRootPart, Handle)
    if ALWAYS_PIERCE_NAMES[hitPart.Name] then
        return true
    end

    --=================================================================
    -- TIER 2: STRUCTURAL CONTEXT
    -- The part itself might look solid, but its parent/context tells us
    -- it's not map geometry.
    --=================================================================

    local parent = hitPart.Parent
    if parent then
        -- Accessories (hats, hair, back items) and Tools
        -- Their Handle parts often have CanCollide=true but are worn items,
        -- not map structures.
        if parent:IsA("Accessory") or parent:IsA("Tool") or parent:IsA("BackpackItem") then
            return true
        end

        -- Another player's body parts: characters standing between us and
        -- the target are not walls. We check for Humanoid as the definitive
        -- marker of a character model.
        if parent:IsA("Model") and parent:FindFirstChildOfClass("Humanoid") then
            return true
        end

        -- Known container folders for transient/non-structural objects
        local pName = parent.Name:lower()
        if PIERCE_PARENT_NAMES[pName] then
            return true
        end
    end

    -- ForceField: visual shield effect, not physical geometry
    if hitPart:FindFirstChildOfClass("ForceField") then
        return true
    end
    if parent and parent:FindFirstChildOfClass("ForceField") then
        return true
    end

    --=================================================================
    -- TIER 3: CONSERVATIVE HEURISTIC
    -- Only applies to parts that passed Tier 1 and 2 (CanCollide=true,
    -- not an accessory, not a character, Transparency < 0.9).
    -- At 0.75+ transparency the part is barely visible ‚ÄĒ almost certainly
    -- an invisible boundary rather than intentional cover.
    --=================================================================

    if hitPart.Transparency >= RayConfig.TransparencyThreshold then
        return true
    end

    --=================================================================
    -- DEFAULT: TREAT AS SOLID WALL
    -- MeshParts, UnionOperations, thin parts, semi-transparent geometry
    -- (0.1‚Äď0.74) are all treated as legitimate obstacles. If the collision
    -- box is oversized relative to the visual mesh, the multi-ray fallback
    -- in Section 3 handles it geometrically (offset rays miss the box).
    --=================================================================

    return false
end

--=============================================================================
-- SECTION 3: MULTI-RAY LINE-OF-SIGHT ENGINE
-- Primary ray to part center + fallback offset rays for edge cases.
-- If ANY ray has clear LoS, the part is considered visible.
--=============================================================================

-- Pierce raycast: punches through filtered objects up to maxDepth.
-- Uses the global LoS pool (ignorePool/ignorePoolSize) so pierced objects
-- accumulate across multiple calls for the same player's limbs.
local function castPierceRay(origin, targetPos, maxDepth)
    local direction = targetPos - origin

    for _ = 1, maxDepth do
        losRayParams.FilterDescendantsInstances = ignorePool
        local hit = workspace:Raycast(origin, direction, losRayParams)

        if not hit then
            return true  -- Clear line of sight, nothing in the way
        end

        if shouldPierceHit(hit.Instance) then
            poolAdd(hit.Instance)
            -- Advance origin past the hit surface (0.01 stud epsilon to avoid re-hit)
            local hitPos = hit.Position + hit.Normal * 0.01
            direction = targetPos - hitPos
            origin = hitPos
        else
            return false  -- Solid obstacle, blocked
        end
    end

    return false  -- Exceeded pierce depth, assume blocked
end

-- Full visibility check: primary ray + fallback offset rays + caching
local function checkVisibility(origin, targetPart)
    local cached, wasHit = visCacheGet(targetPart)
    if wasHit then return cached end

    local targetPos = targetPart.Position

    -- Primary ray: camera ‚Üí part center
    if castPierceRay(origin, targetPos, RayConfig.MaxPierceDepth) then
        visCacheSet(targetPart, true)
        return true
    end

    -- Primary blocked ‚ÄĒ try offset rays to part edges.
    -- If center is blocked by edge geometry but sides are clear, these catch it.
    -- Offsets use the part's local axes so they make geometric sense regardless
    -- of part orientation.
    local partSize = targetPart.Size
    local cframe   = targetPart.CFrame

    local offsets = {
        cframe.RightVector * (partSize.X * RayConfig.PartSizeOffset),
        cframe.UpVector    * (partSize.Y * RayConfig.PartSizeOffset),
    }

    for i = 1, RayConfig.FallbackRayCount do
        local offset = offsets[i]
        if offset then
            if castPierceRay(origin, targetPos + offset, RayConfig.MaxPierceDepth) then
                visCacheSet(targetPart, true)
                return true
            end
        end
    end

    visCacheSet(targetPart, false)
    return false
end

--=============================================================================
-- SECTION 4: CHARACTER & TEAM UTILITIES
--=============================================================================

local function getUIContainer()
    local success, _ = pcall(function() return CoreGui.Name end)
    if success and CoreGui then return CoreGui end
    return player:WaitForChild("PlayerGui")
end

local guiParent = getUIContainer()

local function getCharacter(plr)
    if plr.Character then return plr.Character end

    local charsFolder = workspace:FindFirstChild("Characters")
    if charsFolder then
        for _, teamFolder in ipairs(charsFolder:GetChildren()) do
            local char = teamFolder:FindFirstChild(plr.Name)
            if char then return char end
        end
    end
    return nil
end

local function getPlayerTeamFolder(plr)
    local char = getCharacter(plr)
    if char and char.Parent then
        return char.Parent.Name
    end
    return nil
end

local function isSameTeam(otherPlayer)
    -- Refresh team cache every 0.5s to avoid stale lookups
    local now = tick()
    if now - teamCacheTick > 0.5 then
        table.clear(teamCache)
        teamCacheTick = now
    end

    local myTeam = teamCache[player]
    if not myTeam then
        myTeam = getPlayerTeamFolder(player) or ""
        teamCache[player] = myTeam
    end

    local theirTeam = teamCache[otherPlayer]
    if not theirTeam then
        theirTeam = getPlayerTeamFolder(otherPlayer) or ""
        teamCache[otherPlayer] = theirTeam
    end

    if myTeam ~= "" and theirTeam ~= "" and myTeam == theirTeam then return true end
    if player.Team and otherPlayer.Team and player.Team == otherPlayer.Team then return true end
    return false
end

local function shouldSkip(otherPlayer)
    return Config.TeamCheck and isSameTeam(otherPlayer)
end

--=============================================================================
-- SECTION 5: VISUALIZATION MANAGEMENT
--=============================================================================

local function clearVisualization(character)
    for _, obj in ipairs(character:GetDescendants()) do
        if obj.Name == VIZ_TAG and obj:IsA("Highlight") then
            obj:Destroy()
        end
    end
end

-- Target part name list: cached and only rebuilt when body part toggles change.
-- Avoids rebuilding a table of 15+ strings every applyVisualization call.
local cachedTargetNames = nil
local cachedTargetMap   = nil

local function getTargetNames()
    if cachedTargetNames then return cachedTargetNames, cachedTargetMap end

    cachedTargetNames = {}
    cachedTargetMap   = {}

    local function addParts(list)
        for _, n in ipairs(list) do
            cachedTargetNames[#cachedTargetNames + 1] = n
            cachedTargetMap[n] = true
        end
    end

    if Config.ShowHead  then addParts(Config.HeadParts)  end
    if Config.ShowTorso then addParts(Config.TorsoParts) end
    if Config.ShowArms  then addParts(Config.ArmParts)   end
    if Config.ShowLegs  then addParts(Config.LegParts)   end

    return cachedTargetNames, cachedTargetMap
end

local function invalidateTargetNameCache()
    cachedTargetNames = nil
    cachedTargetMap   = nil
end

local function applyVisualization(otherPlayer, character)
    clearVisualization(character)
    local activeAdornments = {}

    if not Config.Enabled then return activeAdornments end
    if shouldSkip(otherPlayer) then return activeAdornments end

    local targetNames, targetNamesMap = getTargetNames()

    for _, partName in ipairs(targetNames) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            local box = Instance.new("Highlight")
            box.Name                = VIZ_TAG
            box.Adornee             = part
            box.FillColor           = Config.ColorVisible
            box.OutlineColor        = Config.ColorVisible
            box.FillTransparency    = Config.Transparency
            box.OutlineTransparency = Config.OutlineTransp
            box.DepthMode           = Config.ShowThroughWalls
                and Enum.HighlightDepthMode.AlwaysOnTop
                or Enum.HighlightDepthMode.Occluded
            box.Parent              = part
            activeAdornments[#activeAdornments + 1] = box
        end
    end

    -- Accessory occlusion fix: when NOT using AlwaysOnTop, accessories would
    -- render on top of body highlights creating visual glitches. Adding Occluded
    -- highlights to accessory parts fixes the layering.
    if not Config.ShowThroughWalls then
        for _, obj in ipairs(character:GetDescendants()) do
            if obj:IsA("BasePart") and not targetNamesMap[obj.Name] then
                local box = Instance.new("Highlight")
                box.Name                = VIZ_TAG
                box.Adornee             = obj
                box.FillColor           = Config.ColorVisible
                box.OutlineColor        = Config.ColorVisible
                box.FillTransparency    = Config.Transparency
                box.OutlineTransparency = Config.OutlineTransp
                box.DepthMode           = Enum.HighlightDepthMode.Occluded
                box.Parent              = obj
                activeAdornments[#activeAdornments + 1] = box
            end
        end
    end

    return activeAdornments
end

local function wipeAllVisualizations()
    for _, state in pairs(trackedState) do
        if state.character then clearVisualization(state.character) end
    end
    trackedState = {}
    trackedPlayerCount = 0
    visCacheFlush()
end

--=============================================================================
-- SECTION 6: MAIN UPDATE LOOPS
--=============================================================================

-- State tracking: detect new/changed characters, apply highlight instances
task.spawn(function()
    while task.wait(0.5) do
        if not Config.Enabled then continue end

        for _, p in ipairs(Players:GetPlayers()) do
            if p == player then continue end

            local char = getCharacter(p)
            local currentTeam = char and char.Parent and char.Parent.Name or nil

            if char then
                local state = trackedState[p]

                if not state or state.character ~= char or state.teamFolder ~= currentTeam then
                    if not state then trackedPlayerCount += 1 end
                    local adornments = applyVisualization(p, char)
                    trackedState[p] = {
                        character  = char,
                        teamFolder = currentTeam,
                        adornments = adornments,
                    }
                end
            else
                if trackedState[p] then trackedPlayerCount -= 1 end
                trackedState[p] = nil
            end
        end
    end
end)

-- LoS color update: smart pierce raycasting with caching, runs every Heartbeat
RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not Config.DynamicColor then return end

    local camera = workspace.CurrentCamera
    if not camera then return end
    local origin   = camera.CFrame.Position
    local localChar = player.Character

    -- Prevent unbounded cache growth during long sessions
    if visCacheCount > RayConfig.VisCacheMaxSize then
        visCacheFlush()
    end

    for p, state in pairs(trackedState) do
        if not p.Parent then continue end
        if not state.character or not state.adornments then continue end
        local adornments = state.adornments
        if #adornments == 0 then continue end

        local targetChar = state.character

        -- Distance culling
        local targetCore = targetChar:FindFirstChild("HumanoidRootPart") or targetChar.PrimaryPart
        if not targetCore then continue end
        if (targetCore.Position - origin).Magnitude > Config.RenderDistance then continue end

        -- Prepare pierce pool for this player.
        -- Pierced objects accumulate across limbs (if the ray pierced object X
        -- checking the head, it stays filtered for the torso check too).
        poolClear()
        if localChar then poolAdd(localChar) end
        poolAdd(targetChar)

        for _, box in ipairs(adornments) do
            local targetPart = box.Adornee
            if not targetPart or not targetPart.Parent then continue end

            local isVisible  = checkVisibility(origin, targetPart)
            local targetColor = isVisible and Config.ColorVisible or Config.ColorHidden

            -- Only write property if changed (avoids internal Roblox property dirtying)
            if box.FillColor ~= targetColor then
                box.FillColor    = targetColor
                box.OutlineColor = targetColor
            end
        end
    end
end)

Players.PlayerRemoving:Connect(function(p)
    if trackedState[p] then trackedPlayerCount -= 1 end
    trackedState[p] = nil
end)

