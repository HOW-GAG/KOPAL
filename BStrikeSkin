local activeDropdown = nil

local function makeDropdown(parent, label, options, default, order, callback)
    local row=Instance.new("Frame")
    row.Size=UDim2.new(1,0,0,54)
    row.BackgroundColor3=CFG.BG3
    row.AutomaticSize=Enum.AutomaticSize.None
    row.BorderSizePixel=0
    row.LayoutOrder=order or 0
    row.ClipsDescendants=false
    row.ZIndex=10
    row.Parent=parent
    corner(row,9)

    local lbl=mLabel(row,label,12,CFG.TEXT1,Enum.Font.GothamBold)
    lbl.Size=UDim2.new(1,-170,0,18); lbl.Position=UDim2.new(0,14,0,18)
    lbl.TextTruncate=Enum.TextTruncate.AtEnd

    local currentVal=default or (options and options[1]) or "None"

    local dispBtn=Instance.new("TextButton")
    dispBtn.Size=UDim2.new(0,148,0,30)
    dispBtn.Position=UDim2.new(1,-158,0.5,-15)
    dispBtn.BackgroundColor3=CFG.BG4
    dispBtn.Text=currentVal
    dispBtn.TextColor3=CFG.TEXT1
    dispBtn.TextSize=11
    dispBtn.Font=Enum.Font.GothamSemibold
    dispBtn.AutoButtonColor=false
    dispBtn.TextTruncate=Enum.TextTruncate.AtEnd
    dispBtn.Parent=row
    corner(dispBtn,7)
    stroke(dispBtn,Color3.fromRGB(45,45,72),1)
    mPad(dispBtn,8,24,0,0)

    local chev=mLabel(dispBtn,"▾",11,CFG.TEXT2,Enum.Font.GothamBold,Enum.TextXAlignment.Right)
    chev.Size=UDim2.new(0,20,1,0); chev.Position=UDim2.new(1,-22,0,0)

    local list=Instance.new("Frame")
    list.Size=UDim2.new(0,148,0,0)
    list.BackgroundColor3=CFG.BG2
    list.BorderSizePixel=0
    list.ClipsDescendants=true
    list.ZIndex=200
    list.Visible=false
    list.Parent=ScreenGui
    corner(list,8)
    stroke(list,Color3.fromRGB(42,42,70),1.5)

    local scrollFrame=Instance.new("ScrollingFrame")
    scrollFrame.Size=UDim2.new(1,0,1,0)
    scrollFrame.BackgroundTransparency=1
    scrollFrame.BorderSizePixel=0
    scrollFrame.ScrollBarThickness=3
    scrollFrame.ScrollBarImageColor3=CFG.ACCENT
    scrollFrame.CanvasSize=UDim2.new(0,0,0,0)
    scrollFrame.ScrollingDirection=Enum.ScrollingDirection.Y
    scrollFrame.ZIndex=201
    scrollFrame.Parent=list

    local listLayout=Instance.new("UIListLayout")
    listLayout.Padding=UDim.new(0,2)
    listLayout.SortOrder=Enum.SortOrder.LayoutOrder
    listLayout.Parent=scrollFrame
    mPad(scrollFrame,4,4,4,4)

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollFrame.CanvasSize=UDim2.new(0,0,0,listLayout.AbsoluteContentSize.Y+8)
    end)

    local isOpen=false
    local itemBtns={}

    local function updateListPosition()
        local abs=dispBtn.AbsolutePosition
        local absSize=dispBtn.AbsoluteSize
        list.Position=UDim2.new(0,abs.X,0,abs.Y+absSize.Y+4)
        list.Size=UDim2.new(0,dispBtn.AbsoluteSize.X,0,0)
    end

    local function closeList()
        isOpen=false
        tw(list,{Size=UDim2.new(0,dispBtn.AbsoluteSize.X,0,0)},0.18,Enum.EasingStyle.Quad):Play()
        task.delay(0.18,function()
            if not isOpen then list.Visible=false end
        end)
        tw(chev,{Rotation=0,TextColor3=CFG.TEXT2},0.15):Play()
        if activeDropdown==list then activeDropdown=nil end
    end

    local function buildList(opts)
        for _,b in ipairs(itemBtns) do b:Destroy() end
        itemBtns={}
        for i,opt in ipairs(opts) do
            local ib=Instance.new("TextButton")
            ib.Size=UDim2.new(1,0,0,28)
            ib.BackgroundColor3=opt==currentVal and CFG.BG4 or CFG.BG3
            ib.Text=opt
            ib.TextColor3=opt==currentVal and CFG.TEXT1 or CFG.TEXT2
            ib.TextSize=11
            ib.Font=Enum.Font.GothamSemibold
            ib.AutoButtonColor=false
            ib.LayoutOrder=i
            ib.TextTruncate=Enum.TextTruncate.AtEnd
            ib.ZIndex=202
            ib.Parent=scrollFrame
            corner(ib,6)
            mPad(ib,8,0,0,0)

            hov(ib,opt==currentVal and CFG.BG4 or CFG.BG3)

            ib.MouseButton1Click:Connect(function()
                currentVal=opt
                dispBtn.Text=opt
                for _,b2 in ipairs(itemBtns) do
                    b2.BackgroundColor3=b2.Text==opt and CFG.BG4 or CFG.BG3
                    b2.TextColor3=b2.Text==opt and CFG.TEXT1 or CFG.TEXT2
                end
                closeList()
                if callback then callback(opt) end
            end)
            table.insert(itemBtns,ib)
        end
    end

    buildList(options or {})

    dispBtn.MouseButton1Click:Connect(function()
        if isOpen then
            closeList()
        else
            if activeDropdown and activeDropdown~=list then
                tw(activeDropdown,{Size=UDim2.new(0,activeDropdown.AbsoluteSize.X,0,0)},0.18,Enum.EasingStyle.Quad):Play()
                task.delay(0.18,function() activeDropdown.Visible=false end)
                activeDropdown=nil
            end

            isOpen=true
            activeDropdown=list
            updateListPosition()
            list.Visible=true

            local totalH=listLayout.AbsoluteContentSize.Y+10
            local clampedH=math.min(totalH,180)
            tw(list,{Size=UDim2.new(0,dispBtn.AbsoluteSize.X,0,clampedH)},0.18,Enum.EasingStyle.Quad):Play()
            tw(chev,{Rotation=180,TextColor3=CFG.ACCENT},0.15):Play()
        end
    end)

    UserInputService.InputBegan:Connect(function(inp,gp)
        if gp then return end
        if isOpen and inp.UserInputType==Enum.UserInputType.MouseButton1 then
            local mPos=UserInputService:GetMouseLocation()
            local lPos=list.AbsolutePosition
            local lSize=list.AbsoluteSize
            local dPos=dispBtn.AbsolutePosition
            local dSize=dispBtn.AbsoluteSize
            local inList=mPos.X>=lPos.X and mPos.X<=lPos.X+lSize.X
                      and mPos.Y>=lPos.Y and mPos.Y<=lPos.Y+lSize.Y
            local inBtn=mPos.X>=dPos.X and mPos.X<=dPos.X+dSize.X
                     and mPos.Y>=dPos.Y and mPos.Y<=dPos.Y+dSize.Y
            if not inList and not inBtn then
                closeList()
            end
        end
    end)

    local function setOptions(opts)
        buildList(opts)
        if not table.find(opts,currentVal) then
            currentVal=opts[1] or "None"
            dispBtn.Text=currentVal
        end
    end

    return setOptions, function() return currentVal end
end

