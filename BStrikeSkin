local SAVE_FILE = "BloxStrike_Settings.json"

local function saveSettings()
    local data = {
        scriptRunning      = scriptRunning,
        SkinChangerEnabled = SkinChangerEnabled,
        selectedKnife      = selectedKnife,
        SelectedSkins      = SelectedSkins,
    }
    local ok, err = pcall(function()
        writefile(SAVE_FILE, HttpService:JSONEncode(data))
    end)
    if not ok then warn("[BloxStrike] Failed to save: "..tostring(err)) end
end

local function loadSettings()
    if not isfile(SAVE_FILE) then return nil end
    local ok, result = pcall(function()
        return HttpService:JSONDecode(readfile(SAVE_FILE))
    end)
    if ok and result then return result end
    warn("[BloxStrike] Save file corrupted, using defaults.")
    return nil
end

-- Apply saved values to variables BEFORE the GUI reads them
local saved = loadSettings()
if saved then
    scriptRunning      = saved.scriptRunning      or false
    SkinChangerEnabled = saved.SkinChangerEnabled or false
    selectedKnife      = saved.selectedKnife      or "Butterfly Knife"
    SelectedSkins      = saved.SelectedSkins      or {}
end
