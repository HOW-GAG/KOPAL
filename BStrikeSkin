    pd.PaddingTop=UDim.new(0,t or 0);  pd.PaddingBottom=UDim.new(0,b or 0)
    pd.Parent=p
end
local function hov(btn, base)
    btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=base:Lerp(Color3.new(1,1,1),0.14)},0.1):Play() end)
    btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=base},0.1):Play() end)
