--// Utilities

local function tween(obj, props, t, style, dir)
	local info = TweenInfo.new(
		t or CONFIG.UI.AnimSpeed,
		style or Enum.EasingStyle.Quint,
		dir or Enum.EasingDirection.Out
	)
	TweenService:Create(obj, info, props):Play()
end

local function applyCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or CONFIG.UI.CornerRadius)
	c.Parent = parent
	return c
end

local function applyStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or CONFIG.Colors.Border
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0.5
	s.Parent = parent
	return s
end

local function applyPadding(parent, all, left, right, top, bottom)
	local p = Instance.new("UIPadding")
	if all then
		p.PaddingLeft   = UDim.new(0, all)
		p.PaddingRight  = UDim.new(0, all)
		p.PaddingTop    = UDim.new(0, all)
		p.PaddingBottom = UDim.new(0, all)
	else
		if left   then p.PaddingLeft   = UDim.new(0, left)   end
		if right  then p.PaddingRight  = UDim.new(0, right)  end
		if top    then p.PaddingTop    = UDim.new(0, top)    end
		if bottom then p.PaddingBottom = UDim.new(0, bottom) end
	end
	p.Parent = parent
	return p
end

local function makeLabel(parent, text, size, color, font, xAlign, yAlign)
	local l = Instance.new("TextLabel")
	l.Text = text or ""
	l.TextSize = size or 13
	l.TextColor3 = color or CONFIG.Colors.TextPrimary
	l.Font = font or Enum.Font.GothamMedium
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
	l.TextYAlignment = yAlign or Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Size = UDim2.new(1, 0, 1, 0)
	l.Parent = parent
	return l
end

--// File I/O
local function loadSavedData()
	if isfile and readfile then
		local ok, raw = pcall(readfile, CONFIG.SaveFileName)
		if ok and raw then
			local ok2, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
			if ok2 and type(decoded) == "table" then
				savedStickersDB = decoded
			end
		end
	end
end

local function saveCurrentData()
	if writefile then
		local ok, enc = pcall(function() return HttpService:JSONEncode(savedStickersDB) end)
		if ok then pcall(writefile, CONFIG.SaveFileName, enc) end
	end
end

--// Cleanup
local function cleanupOldGUI()
	local existing = guiContainer:FindFirstChild("StickerVaultV3")
	if existing then existing:Destroy() end
	for _, c in ipairs(activeConnections) do
		if c.Connected then c:Disconnect() end
	end
	table.clear(activeConnections)
	table.clear(uiInstances)
end

--// Data helpers
local function extractAssetId(tex)
	return tex and string.match(tex, "%d+") or nil
end

local function getStickerFolder(jeepney)
	local b = jeepney:FindFirstChild("Body")
	if not b then return nil end
	local s = b:FindFirstChild("Structure")
	if not s then return nil end
	local c = s:FindFirstChild("Customizables")
	if not c then return nil end
	return c:FindFirstChild("Stickers")
end

