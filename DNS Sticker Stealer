		uiInstances.PreviewIDLabel.Visible = true
		uiInstances.PreviewIDLabel.Text = "ID: " .. id
		uiInstances.PreviewOwnerLabel.Visible = true
		uiInstances.PreviewOwnerLabel.Text = "Owner: " .. ownerName
	end)

	CopyBtn.MouseButton1Click:Connect(function()
		if setclipboard then
			pcall(setclipboard, id)
			CopyBtn.Text = "✓"
			task.wait(1.2)
			CopyBtn.Text = "COPY"
		end
	end)

	ActionBtn.MouseButton1Click:Connect(function()
		if isSavedMode then
			savedStickersDB[id] = nil
			saveCurrentData()
			tween(Card, {BackgroundTransparency = 1}, 0.2)
			task.wait(0.2)
			Card:Destroy()
			refreshActiveUI()
		else
			if savedStickersDB[id] then return end
			savedStickersDB[id] = { owner = ownerName }
			saveCurrentData()
			ActionBtn.Text = "SAVED ✓"
			tween(ActionBtn, {BackgroundColor3 = CONFIG.Colors.SaveDim}, 0.15)
			ActionBtn.Active = false
			refreshSavedUI()
		end
	end)
end

-----------------------------
-- Refresh Helpers
-----------------------------
function refreshActiveUI()
	if not uiInstances.ActiveScroll then return end
	for _, c in ipairs(uiInstances.ActiveScroll:GetChildren()) do
		if c:IsA("GuiObject") then c:Destroy() end
	end

	local count = 0
	if targetFolder then
		for _, jeepney in ipairs(targetFolder:GetChildren()) do
			local sf = getStickerFolder(jeepney)
			if sf then
				for _, obj in ipairs(sf:GetChildren()) do
					local decal = obj:FindFirstChildWhichIsA("Decal") or obj:FindFirstChildWhichIsA("Texture")
					if decal and decal.Texture ~= "" then
						local id = extractAssetId(decal.Texture)
						if id then
							createStickerEntry(uiInstances.ActiveScroll, id, jeepney.Name, false)
							count += 1
						end
					end
				end
			end
		end
	end

	if count == 0 then
		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(1, 0, 0, 40)
		lbl.BackgroundTransparency = 1
		lbl.Text = count == 0 and "No vehicles detected. Waiting..." or ""
		lbl.TextColor3 = CONFIG.Colors.TextMuted
		lbl.TextSize = 12
		lbl.Font = Enum.Font.Gotham
		lbl.Name = "_EmptyLabel"
		lbl.Parent = uiInstances.ActiveScroll
	end

	task.defer(function()
		uiInstances.ActiveScroll.CanvasSize = UDim2.new(0, 0, 0, uiInstances.ActiveLayout.AbsoluteContentSize.Y + 10)
	end)
end

function refreshSavedUI()
	if not uiInstances.SavedScroll then return end
	for _, c in ipairs(uiInstances.SavedScroll:GetChildren()) do
		if c:IsA("GuiObject") then c:Destroy() end
	end

	local count = 0
	for id, data in pairs(savedStickersDB) do
		createStickerEntry(uiInstances.SavedScroll, id, data.owner, true)
		count += 1
	end

	if count == 0 then
		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(1, 0, 0, 40)
		lbl.BackgroundTransparency = 1
		lbl.Text = "No stickers saved yet."
		lbl.TextColor3 = CONFIG.Colors.TextMuted
		lbl.TextSize = 12
		lbl.Font = Enum.Font.Gotham
		lbl.Name = "_EmptyLabel"
		lbl.Parent = uiInstances.SavedScroll
	end

	task.defer(function()
		uiInstances.SavedScroll.CanvasSize = UDim2.new(0, 0, 0, uiInstances.SavedLayout.AbsoluteContentSize.Y + 10)
	end)
end

-----------------------------
-- Main
-----------------------------
loadSavedData()
createUI()
refreshSavedUI()

if targetFolder then
	refreshActiveUI()

	table.insert(activeConnections, targetFolder.ChildAdded:Connect(function()
		task.wait(1.5)
		refreshActiveUI()
	end))
	table.insert(activeConnections, targetFolder.ChildRemoved:Connect(function()
		refreshActiveUI()
	end))
else
	warn("[StickerVault] Folder 'Jeepnies' not found in Workspace.")
end
