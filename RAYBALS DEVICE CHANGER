-- Function to create buttons
local function createButton(text, position, controlType)
    local button = Instance.new("TextButton")
    button.Name = text .. "Button"
    button.Size = UDim2.new(0, 310, 0, 45)
    button.Position = position
    button.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    button.BorderSizePixel = 2
    button.BorderColor3 = Color3.fromRGB(0, 200, 80)
    button.Text = "[ " .. text .. " ]"
    button.TextColor3 = Color3.fromRGB(0, 255, 100)
    button.Font = Enum.Font.Code
    button.TextSize = 16
    button.Parent = contentFrame
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 8)
    buttonCorner.Parent = button
    
    local buttonGlow = Instance.new("UIStroke")
    buttonGlow.Color = Color3.fromRGB(0, 255, 100)
    buttonGlow.Thickness = 0
    buttonGlow.Transparency = 1
    buttonGlow.Parent = button
    
    -- Hover effect
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(0, 50, 20)
        buttonGlow.Thickness = 2
        buttonGlow.Transparency = 0.3
    end)
    
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
        buttonGlow.Thickness = 0
        buttonGlow.Transparency = 1
    end)
    
    -- Click event
    button.MouseButton1Click:Connect(function()
        local ReplicatedStorage = game:GetService('ReplicatedStorage')
        ReplicatedStorage.Remotes.Replication.Fighter.SetControls:FireServer(controlType)
        
        -- Visual feedback
        button.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        button.TextColor3 = Color3.fromRGB(0, 0, 0)
        wait(0.3)
        button.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
        button.TextColor3 = Color3.fromRGB(0, 255, 100)
        
        print("⚡ Controls set to: " .. controlType)
    end)
    
    return button
end

