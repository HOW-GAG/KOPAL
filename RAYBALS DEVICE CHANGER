-- Create multiple binary columns
local function createBinaryColumn(xPos)
    local column = Instance.new("TextLabel")
    column.Size = UDim2.new(0, 20, 2, 0)
    column.Position = UDim2.new(0, xPos, -1, 0)
    column.BackgroundTransparency = 1
    column.TextColor3 = Color3.fromRGB(0, 255, 100)
    column.TextTransparency = 0.7
    column.Font = Enum.Font.Code
    column.TextSize = 12
    column.TextXAlignment = Enum.TextXAlignment.Center
    column.Parent = binaryContainer
    
    -- Generate random binary text
    local binaryText = ""
    for i = 1, 100 do
        binaryText = binaryText .. (math.random(0, 1)) .. "\n"
    end
    column.Text = binaryText
    
    -- Animate falling
    spawn(function()
        local speed = math.random(3, 7)
        while column and column.Parent do
            column:TweenPosition(
                UDim2.new(0, xPos, 1, 0),
                Enum.EasingDirection.InOut,
                Enum.EasingStyle.Linear,
                speed,
                true
            )
            wait(speed)
            column.Position = UDim2.new(0, xPos, -1, 0)
            
            -- Regenerate binary text
            binaryText = ""
            for i = 1, 100 do
                binaryText = binaryText .. (math.random(0, 1)) .. "\n"
            end
            column.Text = binaryText
        end
    end)
    
    return column
end

-- Create multiple columns across the frame
for i = 0, 350, 25 do
    createBinaryColumn(i)
end

