local minimized = false
local FULL_SIZE = UDim2.new(0, 280, 0, 450)
local MINI_SIZE = UDim2.new(0, 280, 0, 52)

MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    TweenService:Create(Panel, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {
        Size = minimized and MINI_SIZE or FULL_SIZE
    }):Play()
    MinBtn.Text = minimized and "+" or "‚ÄĒ"
end)

Panel.Size = UDim2.new(0, 280, 0, 0)
Panel.BackgroundTransparency = 1
TweenService:Create(Panel, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
    Size = FULL_SIZE,
    BackgroundTransparency = 0,
}):Play()

-- F5 to toggle GUI visibility
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F5 then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

